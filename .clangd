# Root-level Clangd configuration for Kiosk Application
# This file provides IntelliSense context for mixed Dart/C++ projects.

# Hardware-specific settings for Arduino/ESP32 files
If:
  PathMatch: hardware/.*

CompileFlags:
  Add: 
    - "--driver-mode=g++"
    - "-xc++"
    - "-std=c++17"
    # Force-include Arduino.h to resolve "Unknown type String/Serial/etc" errors
    - "-include"
    - "Arduino.h"
    - "-DARDUINO=10813"
    - "-DARDUINO_ARCH_ESP32"
    - "-DESP32"
    # Board Core and Variant
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/cores/esp32"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/variants/esp32"
    # Essential SDK Headers (v3.3.8 structure)
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/esp_system"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/esp_hw_support"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/driver"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/soc"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/hal"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/freertos"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/esp_common"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/esp_timer"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/log"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/newlib"
    # Libraries
    - "-IC:/ArduinoLibs/libraries/Adafruit_MLX90614_Library/src"
    - "-IC:/ArduinoLibs/libraries/HX711/src"
    - "-IC:/ArduinoLibs/libraries/ArduinoJson/src"
    - "-IC:/ArduinoLibs/libraries/Adafruit_BusIO/src"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/libraries/Wire/src"
  
  CompilationDatabase: "hardware/esp32_sensor_hub"

Diagnostics:
  Suppress: 
    - "drv_compilation_interpreter_failed"
    - "pp_file_not_found"

---
# Compiler specific flags and background indexing settings
Index:
  Background: true

