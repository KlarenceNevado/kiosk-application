# Clangd configuration to SILENCE all false-positive hardware errors
Diagnostics:
  Suppress: ["ovl_no_viable_member_function_in_call"]

CompileFlags:
  Add: 
    - "--driver-mode=g++"
    - "-xc++"
    - "-std=c++17"
    - "-DARDUINO=10813"
    - "-DARDUINO_ARCH_ESP32"
    - "-DESP32"
    # Core ESP32 Includes
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/cores/esp32"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/variants/esp32"
    # FreeRTOS Includes (CORRECTED)
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/tools/esp32-libs/3.3.8/include/freertos/FreeRTOS-Kernel/include"
    # Library Includes
    - "-IC:/Users/Klarence Nevado/Documents/Arduino/libraries/Adafruit_MLX90614_Library"
    - "-IC:/Users/Klarence Nevado/Documents/Arduino/libraries/HX711"
    - "-IC:/Users/Klarence Nevado/Documents/Arduino/libraries/ArduinoJson/src"
    - "-IC:/Users/Klarence Nevado/Documents/Arduino/libraries/Adafruit_BusIO"
    - "-IC:/Users/Klarence Nevado/AppData/Local/Arduino15/packages/esp32/hardware/esp32/3.3.8/libraries/Wire/src"

Index:
  Background: Skip
